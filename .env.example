# WikiTree MCP server configuration. Copy to .env and fill in as needed.
#
# Authentication is OPTIONAL. With no credentials, the server reads PUBLIC
# WikiTree data only. Provide your WikiTree login to also access private/living
# profiles that your account is permitted to see.
WIKITREE_EMAIL=
WIKITREE_PASSWORD=

# Identifies this client to the WikiTree API in request logs. Optional.
WIKITREE_APP_ID=ActyraWikiTreeMCP
